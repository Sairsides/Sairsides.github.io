---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import LinkCard from "../components/LinkCard.astro";
import CertificateCard from "../components/CertificateCard.astro";
import BadgeCard from "../components/BadgeCard.astro";
import { profile } from "../data/profile";
---
<BaseLayout>
  <Hero name={profile.name} alias={profile.alias} bio={profile.bio} />

  <Section id="socials" title="Social Links">
    <div class="grid">
      {profile.socials.map((s) => <LinkCard {...s} />)}
    </div>
  </Section>

  <Section id="certifications" title="Certifications">
    <CertificateCard {...profile.certificate} />
  </Section>

  <Section id="badges" title="Badges">
    <div class="grid">
      {profile.badges.map((b) => <BadgeCard {...b} />)}
    </div>
  </Section>

  <Section id="live-profile" title="Live Profile">
    <iframe
      src={profile.iframeSrc}
      title="TryHackMe Public Profile"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </Section>
</BaseLayout>