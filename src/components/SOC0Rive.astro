<div class="soc0-wrap" data-soc0-wrap>
  <canvas class="soc0-canvas" width="200" height="200"></canvas>
</div>

<script type="module">
  import Rive from "@rive-app/webgl2";

  const wraps = document.querySelectorAll("[data-soc0-wrap]");
  wraps.forEach((wrap) => {
    const canvas = wrap.querySelector(".soc0-canvas");
    if (!canvas) return;

    // Hide until loaded (prevents empty blank block)
    wrap.classList.add("is-loading");

    const rive = new Rive({
      src: "https://tryhackme.com/static/assets/sec0-animation.2b47979f.riv",
      canvas,
      autoplay: true,
      onLoad: () => {
        wrap.classList.remove("is-loading");
        try { rive.resizeDrawingSurfaceToCanvas(); } catch {}
      },
      onLoadError: () => {
        // If fails, keep hidden so no blank space
        wrap.style.display = "none";
      }
    });
  });
</script>

<style>
  .soc0-wrap{
    width:200px;
    height:200px;
    margin:0 auto 8px;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .soc0-wrap.is-loading{
    height:0;
    margin:0;
    overflow:hidden;
  }
  .soc0-canvas{
    width:200px;
    height:200px;
    display:block;
  }
</style>