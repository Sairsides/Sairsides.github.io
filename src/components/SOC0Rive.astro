<div class="sec0-scene" aria-hidden="true">
  <div class="glow"></div>

  <img
    class="badge"
    src="https://dragkob.com/MainWeb/images/certifications/SEC0.webp"
    alt="SEC0 badge"
    loading="lazy"
  />

  <div class="rings">
    <span></span><span></span><span></span>
  </div>
</div>

<style>
  .sec0-scene{
    --accent: 154,255,68;
    position: relative;
    width: 300px;
    height: 230px;
    margin: 0 auto 12px;
    display: grid;
    place-items: center;
  }

  .glow{
    position:absolute;
    top:34px;
    width:170px;height:170px;border-radius:999px;
    background: radial-gradient(circle, rgba(var(--accent),.32) 0%, rgba(var(--accent),.09) 55%, rgba(var(--accent),0) 75%);
    filter: blur(2px);
    animation: glowPulse 2.4s ease-in-out infinite;
  }

  .badge{
    position: relative;
    z-index: 2;
    width: 132px;
    height: auto;
    filter: drop-shadow(0 0 12px rgba(var(--accent),.38));
    animation: floatY 2.8s ease-in-out infinite;
  }

  .rings{
    position:absolute;
    bottom:8px;
    width:220px;
    height:52px;
    z-index:1;
  }

  .rings span{
    position:absolute;
    inset:0;
    border:2px solid rgba(var(--accent),.42);
    border-radius:50%;
    animation: ripple 2.4s linear infinite;
  }
  .rings span:nth-child(2){ animation-delay:.8s; }
  .rings span:nth-child(3){ animation-delay:1.6s; }

  /* stronger effect on hover */
  .cert-card:hover .badge{
    filter: drop-shadow(0 0 20px rgba(var(--accent),.6));
    transform: scale(1.06);
  }
  .cert-card:hover .glow{
    opacity: 1;
  }

  @keyframes floatY{
    0%,100%{ transform: translateY(0); }
    50%{ transform: translateY(-10px); }
  }

  @keyframes glowPulse{
    0%,100%{ transform: scale(.95); opacity:.75; }
    50%{ transform: scale(1.10); opacity:1; }
  }

  @keyframes ripple{
    0%{ transform: scale(.45); opacity:.82; }
    100%{ transform: scale(1.2); opacity:0; }
  }
</style>