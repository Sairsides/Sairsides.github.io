---
interface Props {
  label: string;
  url: string;
  icon?: string;
}
const { label, url, icon } = Astro.props;
---
<a class="card badge-card" href={url} target="_blank" rel="noopener noreferrer" aria-label={`Open ${label}`}>
  <div class="left">
    {icon && <img src={icon} alt={`${label} icon`} loading="lazy" />}
    <div>
      <h3>{label}</h3>
      <p>View badge</p>
    </div>
  </div>
  <span aria-hidden="true">↗</span>
</a>

<style>
  .badge-card .left{display:flex;align-items:center;gap:12px}
  .badge-card img{
    width:44px;height:44px;object-fit:contain;border-radius:10px;
    background:rgba(255,255,255,.06);padding:4px;
    transition:transform .25s ease, filter .25s ease;
  }
  .badge-card:hover img{transform:scale(1.07) rotate(-3deg);filter:drop-shadow(0 0 10px rgba(217,58,88,.35))}
</style>